# Optional environment variables for mplabs-tts.
# All flags can also be passed via CLI args.

# Path to the F5-TTS checkpoint (.safetensors).
MPLABS_TTS_MODEL=./models/model_last.safetensors

# Path to the F5-TTS vocab file.
MPLABS_TTS_VOCAB=./models/vocab.txt

# Path to the reference voice WAV (5-15 s, clear speech in target language).
MPLABS_TTS_VOICE=./voices/male_narrator.wav

# Transcript of the reference voice (verbatim, lowercase, no punctuation if possible).
MPLABS_TTS_VOICE_TEXT="é muito emocionante os homens se encontrarem à noite no bosque"

# Torch device: mps | cuda | cpu
MPLABS_TTS_DEVICE=mps
